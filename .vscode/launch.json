{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MCW: run.py（本机调试）",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": ["--no-browser", "--reload"],
      "justMyCode": true
    },
    {
      "name": "MCW: run.py（无 reload）",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": ["--no-browser"],
      "justMyCode": true
    }
  ]
}
