# Copy to .env and fill in. Never commit .env with real secrets.

PARATERA_API_KEY=
OPENAI_API_BASE=https://llmapi.paratera.com/v1
OPENAI_CHAT_MODEL=DeepSeek-V4-Flash

# 可选：对话后「板块结构化同步」使用的模型；留空则与 OPENAI_CHAT_MODEL 相同
STRUCTURE_SYNC_MODEL=

# 可选：校对者（proofreader）使用的模型，建议用小模型加速；留空则与 STRUCTURE_SYNC_MODEL 或 OPENAI_CHAT_MODEL 相同
PROOFREADER_MODEL=

# RAG 向量 embedding（章节语义检索）
# auto=本地有缓存则用 bge，否则用 API；api=始终用 API；local=始终尝试从 HuggingFace 下载
# MCW_EMBEDDING_BACKEND=api
# MCW_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 国内网络可设镜像：MCW_HF_ENDPOINT=https://hf-mirror.com
